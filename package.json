{
  "name": "ftz-zone-manager",
  "version": "0.1.0",
  "description": "FTZ Zone Manager - automate FTZ Zone-to-Zone reports",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:3001": "PORT=3001 node server.js",
    "dev:3001": "PORT=3001 nodemon server.js",
    "stop": "pkill -f \"FTZ Zone Manager/server.js\" || true",
    "start:clean": "npm run stop && npm run start:3001"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.0.0",
    "ejs": "^3.1.10",
    "exceljs": "^4.3.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.3.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
